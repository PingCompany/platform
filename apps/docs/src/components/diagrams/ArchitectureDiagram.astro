---
import KrokiDiagram from './KrokiDiagram.astro';

const source = `
graph LR
  A["<b>Next.js 15</b><br/>App Router<br/><i>React 19 · Tailwind · Radix UI · cmdk</i>"]
  B["<b>Convex Backend</b><br/>Serverless<br/><i>Real-time DB · Mutations · Queries · Actions · CRON</i>"]
  C["<b>External Services</b><br/>Integrations<br/><i>WorkOS · OpenAI · GitHub · Linear · Graphiti</i>"]

  A -- "WebSockets<br/>(real-time sync)" --> B
  B -- "Webhooks / API" --> C

  style A fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f
  style B fill:#ede9fe,stroke:#8b5cf6,color:#3b1f7e
  style C fill:#fef3c7,stroke:#f59e0b,color:#78350f
`;
---

<KrokiDiagram source={source} alt="PING Platform component architecture: Next.js frontend, Convex backend, and external services" />
