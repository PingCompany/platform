---
---

<div class="arch">
  <div class="arch-label">PING Platform</div>
  <div class="arch-grid">
    <div class="arch-card" style="--card-accent: #3b82f6; --card-accent-bg: rgba(59,130,246,0.08);">
      <div class="arch-card-header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        <div>
          <div class="arch-card-name">Next.js 15</div>
          <div class="arch-card-sub">App Router</div>
        </div>
      </div>
      <div class="arch-card-items">
        <span class="arch-tag">React 19</span>
        <span class="arch-tag">Tailwind CSS</span>
        <span class="arch-tag">Radix UI</span>
        <span class="arch-tag">cmdk</span>
      </div>
    </div>

    <div class="arch-wire">
      <div class="arch-wire-line">
        <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3" fill="none" stroke="var(--ping-border)" stroke-width="1.5"/></svg>
        <div class="arch-wire-dash"></div>
        <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3" fill="none" stroke="var(--ping-border)" stroke-width="1.5"/></svg>
      </div>
      <span class="arch-wire-text">WebSockets</span>
    </div>

    <div class="arch-card" style="--card-accent: #8b5cf6; --card-accent-bg: rgba(139,92,246,0.08);">
      <div class="arch-card-header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        <div>
          <div class="arch-card-name">Convex Backend</div>
          <div class="arch-card-sub">Serverless</div>
        </div>
      </div>
      <div class="arch-card-items">
        <span class="arch-tag">Real-time DB</span>
        <span class="arch-tag">Mutations</span>
        <span class="arch-tag">Queries</span>
        <span class="arch-tag">Actions</span>
        <span class="arch-tag">CRON jobs</span>
      </div>
    </div>

    <div class="arch-wire">
      <div class="arch-wire-line">
        <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3" fill="none" stroke="var(--ping-border)" stroke-width="1.5"/></svg>
        <div class="arch-wire-dash"></div>
        <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3" fill="none" stroke="var(--ping-border)" stroke-width="1.5"/></svg>
      </div>
      <span class="arch-wire-text">Webhooks / API</span>
    </div>

    <div class="arch-card" style="--card-accent: #f59e0b; --card-accent-bg: rgba(245,158,11,0.08);">
      <div class="arch-card-header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
        <div>
          <div class="arch-card-name">External Services</div>
          <div class="arch-card-sub">Integrations</div>
        </div>
      </div>
      <div class="arch-card-items">
        <span class="arch-tag">WorkOS</span>
        <span class="arch-tag">OpenAI</span>
        <span class="arch-tag">GitHub</span>
        <span class="arch-tag">Linear</span>
        <span class="arch-tag">Graphiti</span>
      </div>
    </div>
  </div>
</div>

<style>
  .arch {
    margin: 1.5rem 0;
    padding: 1.5rem;
    background: var(--ping-surface-raised);
    border: 1px solid var(--ping-border);
    border-radius: 0.75rem;
    overflow-x: auto;
  }

  .arch-label {
    text-align: center;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--ping-text-muted);
    margin-bottom: 1.25rem;
  }

  .arch-grid {
    display: flex;
    align-items: stretch;
    justify-content: center;
    gap: 0;
    min-width: 600px;
  }

  .arch-card {
    flex: 1;
    max-width: 14rem;
    background: var(--ping-surface);
    border: 1px solid var(--ping-border);
    border-radius: 0.625rem;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .arch-card:hover {
    border-color: var(--card-accent);
    box-shadow: 0 0 0 1px var(--card-accent), 0 8px 24px -4px color-mix(in srgb, var(--card-accent) 20%, transparent);
    transform: translateY(-2px);
  }

  .arch-card-header {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1rem;
    border-bottom: 1px solid var(--ping-border);
    background: var(--card-accent-bg);
  }

  .arch-card-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ping-text);
    line-height: 1.2;
  }

  .arch-card-sub {
    font-size: 0.6875rem;
    color: var(--ping-text-muted);
  }

  .arch-card-items {
    padding: 0.75rem 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .arch-tag {
    font-size: 0.6875rem;
    color: var(--ping-text-muted);
    background: var(--ping-surface-raised);
    border: 1px solid var(--ping-border);
    padding: 0.125rem 0.5rem;
    border-radius: 999px;
    white-space: nowrap;
  }

  .arch-card:hover .arch-tag {
    border-color: color-mix(in srgb, var(--card-accent) 30%, transparent);
  }

  .arch-wire {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 5rem;
    flex-shrink: 0;
    gap: 0.375rem;
  }

  .arch-wire-line {
    display: flex;
    align-items: center;
    gap: 0;
    width: 100%;
  }

  .arch-wire-dash {
    flex: 1;
    height: 1px;
    background: repeating-linear-gradient(90deg, var(--ping-border) 0, var(--ping-border) 4px, transparent 4px, transparent 8px);
  }

  .arch-wire-text {
    font-size: 0.5625rem;
    color: var(--ping-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  @media (max-width: 700px) {
    .arch-grid {
      flex-direction: column;
      align-items: center;
      min-width: 0;
      gap: 0;
    }
    .arch-card { max-width: 100%; width: 100%; }
    .arch-wire {
      width: 100%;
      height: 2.5rem;
      flex-direction: row;
      gap: 0.5rem;
    }
    .arch-wire-line {
      width: auto;
      flex-direction: column;
      height: 100%;
    }
    .arch-wire-dash {
      width: 1px;
      height: 100%;
      background: repeating-linear-gradient(180deg, var(--ping-border) 0, var(--ping-border) 4px, transparent 4px, transparent 8px);
    }
  }
</style>
