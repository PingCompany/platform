---
---

<div class="pip">
  <div class="pip-trigger">
    <div class="pip-pulse"></div>
    <span>Message Written</span>
  </div>

  <div class="pip-connector">
    <div class="pip-vline"></div>
    <div class="pip-fork">
      <div class="pip-hline"></div>
      <div class="pip-hline"></div>
    </div>
  </div>

  <div class="pip-branches">
    <div class="pip-branch" style="--b-accent: #3b82f6;">
      <div class="pip-branch-head">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        <span>Inbox Summary</span>
      </div>
      <div class="pip-branch-detail">
        <div class="pip-detail-label">Eisenhower Matrix Ranking</div>
        <div class="pip-quadrants">
          <div class="pip-q"><span class="pip-dot" style="background:#ef4444"></span>Urgent + Important</div>
          <div class="pip-q"><span class="pip-dot" style="background:#f59e0b"></span>Important</div>
          <div class="pip-q"><span class="pip-dot" style="background:#3b82f6"></span>Urgent</div>
          <div class="pip-q"><span class="pip-dot" style="background:#6b7280"></span>FYI</div>
        </div>
      </div>
    </div>

    <div class="pip-branch" style="--b-accent: #f59e0b;">
      <div class="pip-branch-head">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        <span>Proactive Alerts</span>
      </div>
      <div class="pip-branch-detail">
        <div class="pip-detail-label">Alert Types</div>
        <div class="pip-alert-list">
          <span class="pip-alert-tag">Unanswered question</span>
          <span class="pip-alert-tag">PR review nudge</span>
          <span class="pip-alert-tag">Incident routing</span>
          <span class="pip-alert-tag">Blocked task</span>
          <span class="pip-alert-tag">Fact check</span>
          <span class="pip-alert-tag">Cross-team sync</span>
        </div>
      </div>
    </div>

    <div class="pip-branch" style="--b-accent: #10b981;">
      <div class="pip-branch-head">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20M2 12h20"/></svg>
        <span>Knowledge Graph</span>
      </div>
      <div class="pip-branch-detail">
        <div class="pip-detail-label">Graphiti Temporal Graph</div>
        <div class="pip-alert-list">
          <span class="pip-alert-tag">Fact checking</span>
          <span class="pip-alert-tag">Context sync</span>
          <span class="pip-alert-tag">@KnowledgeBot</span>
        </div>
      </div>
    </div>
  </div>

  <div class="pip-connector">
    <div class="pip-fork pip-fork-up">
      <div class="pip-hline"></div>
      <div class="pip-hline"></div>
    </div>
    <div class="pip-vline"></div>
  </div>

  <div class="pip-result">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ping-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    <span>Results written to DB &mdash; real-time push to UI</span>
  </div>
</div>

<style>
  .pip {
    margin: 1.5rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .pip-trigger, .pip-result {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--ping-surface-raised);
    border: 1px solid var(--ping-border);
    border-radius: 999px;
    padding: 0.5rem 1.25rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ping-text);
  }

  .pip-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ping-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--ping-accent) 20%, transparent);
  }

  .pip-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .pip-vline {
    width: 1px;
    height: 1.25rem;
    background: var(--ping-border);
  }

  .pip-fork {
    display: flex;
    width: 66%;
    border-top: 1px solid var(--ping-border);
    justify-content: space-between;
  }

  .pip-fork-up {
    border-top: none;
    border-bottom: 1px solid var(--ping-border);
  }

  .pip-hline {
    width: 1px;
    height: 1rem;
    background: var(--ping-border);
  }

  .pip-fork .pip-hline:first-child { margin-left: calc(50% / 3 * 1 - 0.5px); }
  .pip-fork .pip-hline:last-child { margin-right: calc(50% / 3 * 1 - 0.5px); }

  .pip-branches {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.625rem;
    width: 100%;
  }

  .pip-branch {
    background: var(--ping-surface-raised);
    border: 1px solid var(--ping-border);
    border-radius: 0.625rem;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }

  .pip-branch:hover {
    border-color: var(--b-accent);
    box-shadow: 0 4px 16px -4px color-mix(in srgb, var(--b-accent) 25%, transparent);
    transform: translateY(-2px);
  }

  .pip-branch-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ping-text);
    background: var(--ping-surface);
    border-bottom: 1px solid var(--ping-border);
  }

  .pip-branch-detail {
    padding: 0.75rem 0.875rem;
  }

  .pip-detail-label {
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ping-text-muted);
    margin-bottom: 0.5rem;
  }

  .pip-quadrants {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .pip-q {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: var(--ping-text-muted);
  }

  .pip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .pip-alert-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .pip-alert-tag {
    font-size: 0.6875rem;
    color: var(--ping-text-muted);
    background: var(--ping-surface);
    border: 1px solid var(--ping-border);
    padding: 0.0625rem 0.5rem;
    border-radius: 999px;
  }

  .pip-branch:hover .pip-alert-tag {
    border-color: color-mix(in srgb, var(--b-accent) 30%, transparent);
  }

  @media (max-width: 640px) {
    .pip-branches { grid-template-columns: 1fr; }
    .pip-fork, .pip-fork-up { display: none; }
  }
</style>
