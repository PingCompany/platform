---
import KrokiDiagram from './KrokiDiagram.astro';

const source = `
graph TD
  M["📨 <b>Message Written</b>"]

  M --> S["<b>Inbox Summary</b><br/><i>Eisenhower Matrix Ranking</i>"]
  M --> A["<b>Proactive Alerts</b><br/><i>6 alert types</i>"]
  M --> K["<b>Knowledge Graph</b><br/><i>Graphiti temporal graph</i>"]

  S --> R["✅ <b>Results written to DB</b><br/>Real-time push to UI"]
  A --> R
  K --> R

  style M fill:#ede9fe,stroke:#8b5cf6,color:#3b1f7e
  style S fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f
  style A fill:#fef3c7,stroke:#f59e0b,color:#78350f
  style K fill:#d1fae5,stroke:#10b981,color:#064e3b
  style R fill:#f3f4f6,stroke:#6b7280,color:#1f2937
`;
---

<KrokiDiagram source={source} alt="AI pipeline: message triggers inbox summary, proactive alerts, and knowledge graph processing, results pushed to UI" />
