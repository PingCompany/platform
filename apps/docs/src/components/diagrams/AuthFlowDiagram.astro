---
const lanes = ["User", "Next.js", "WorkOS", "Convex"];
const steps = [
  { n: "1", title: "Login", cells: ["Click Login", "Redirect to WorkOS", "OAuth / SSO provider", ""] },
  { n: "2", title: "Callback", cells: ["", "/callback receives token", "JWT + user info", ""] },
  { n: "3", title: "API Calls", cells: ["", "Include JWT in Convex client", "", "Verify JWT via JWKS"] },
  { n: "4", title: "Authorized", cells: ["See real-time data", "Real-time updates", "", "Function executes"] },
];
---

<div class="af">
  <div class="af-lanes">
    {lanes.map((l) => <div class="af-lane-head">{l}</div>)}
  </div>
  {steps.map((s) => (
    <div class="af-row">
      <div class="af-row-meta">
        <span class="af-num">{s.n}</span>
        <span class="af-row-title">{s.title}</span>
      </div>
      <div class="af-cells">
        {s.cells.map((c) => (
          <div class={`af-cell ${c ? "af-cell-active" : ""}`}>
            {c && <span>{c}</span>}
          </div>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  .af {
    margin: 1.5rem 0;
    background: var(--ping-surface-raised);
    border: 1px solid var(--ping-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .af-lanes {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    padding: 0 0 0 6.5rem;
    background: var(--ping-surface);
    border-bottom: 1px solid var(--ping-border);
  }

  .af-lane-head {
    padding: 0.625rem 0.5rem;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ping-text-muted);
    text-align: center;
  }

  .af-row {
    display: flex;
    border-bottom: 1px solid var(--ping-border);
    transition: background 0.15s;
  }

  .af-row:last-child { border-bottom: none; }

  .af-row:hover {
    background: color-mix(in srgb, var(--ping-accent) 3%, transparent);
  }

  .af-row-meta {
    width: 6.5rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 0.75rem;
    border-right: 1px solid var(--ping-border);
  }

  .af-num {
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    background: var(--sl-color-accent-low);
    color: var(--ping-accent);
    font-size: 0.625rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .af-row:hover .af-num {
    background: var(--ping-accent);
    color: #fff;
  }

  .af-row-title {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--ping-text);
    white-space: nowrap;
  }

  .af-cells {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.375rem;
    padding: 0.5rem;
  }

  .af-cell {
    border-radius: 0.375rem;
    min-height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.375rem 0.5rem;
  }

  .af-cell-active {
    background: var(--ping-surface);
    border: 1px solid var(--ping-border);
  }

  .af-row:hover .af-cell-active {
    border-color: color-mix(in srgb, var(--ping-accent) 40%, transparent);
  }

  .af-cell span {
    font-size: 0.6875rem;
    color: var(--ping-text-muted);
    text-align: center;
    line-height: 1.3;
  }

  @media (max-width: 600px) {
    .af-lanes { padding-left: 0; display: none; }
    .af-row { flex-direction: column; }
    .af-row-meta {
      width: 100%;
      border-right: none;
      border-bottom: 1px solid var(--ping-border);
    }
    .af-cells { grid-template-columns: repeat(2, 1fr); }
  }
</style>
