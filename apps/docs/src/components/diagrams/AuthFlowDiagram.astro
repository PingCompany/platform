---
import KrokiDiagram from './KrokiDiagram.astro';

const source = `
sequenceDiagram
  participant U as User
  participant N as Next.js
  participant W as WorkOS
  participant C as Convex

  U->>N: 1. Click Sign In
  N->>W: Redirect to WorkOS OAuth
  W-->>W: SSO / SAML provider
  W-->>N: 2. Callback with auth code
  N->>N: Exchange for JWT + user info

  N->>C: 3. Convex client includes JWT
  C->>C: Verify JWT via JWKS endpoint

  C-->>N: 4. Authorized — real-time updates
  N-->>U: See live workspace data
`;
---

<KrokiDiagram source={source} alt="Authentication flow: user signs in via WorkOS OAuth/SSO, JWT verified by Convex via JWKS" />
