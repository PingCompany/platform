---
---

<div class="tb">
  <div class="tb-column">
    <div class="tb-node">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--ping-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 16v6H8v-6M12 2v10M8 8l4 4 4-4"/></svg>
      <div class="tb-node-info">
        <div class="tb-node-name">packages/shared</div>
        <code class="tb-node-cmd">build</code>
      </div>
    </div>

    <div class="tb-edge">
      <div class="tb-edge-line"></div>
      <code class="tb-edge-label">^build</code>
      <div class="tb-edge-line"></div>
    </div>

    <div class="tb-node">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--ping-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
      <div class="tb-node-info">
        <div class="tb-node-name">apps/web</div>
        <code class="tb-node-cmd">build</code>
      </div>
    </div>
  </div>

  <div class="tb-sep"></div>

  <div class="tb-parallel">
    <code class="tb-parallel-cmd">lint</code>
    <span class="tb-parallel-desc">all packages &mdash; runs in parallel, no dependencies</span>
  </div>
</div>

<style>
  .tb {
    margin: 1.5rem 0;
    background: var(--ping-surface-raised);
    border: 1px solid var(--ping-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .tb-column {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tb-node {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    background: var(--ping-surface);
    border: 1px solid var(--ping-border);
    border-radius: 0.5rem;
    padding: 0.75rem 1.25rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .tb-node:hover {
    border-color: var(--ping-accent);
    box-shadow: 0 2px 8px rgba(94, 106, 210, 0.12);
  }

  .tb-node-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ping-text);
  }

  .tb-node-cmd {
    font-size: 0.6875rem;
    color: var(--ping-text-muted);
    background: none;
    border: none;
    padding: 0;
  }

  .tb-edge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0;
  }

  .tb-edge-line {
    width: 1px;
    height: 0.75rem;
    background: var(--ping-border);
  }

  .tb-edge-label {
    font-size: 0.625rem;
    color: var(--ping-accent);
    background: var(--sl-color-accent-low);
    border: none;
    padding: 0.0625rem 0.5rem;
    border-radius: 999px;
  }

  .tb-sep {
    height: 1px;
    background: var(--ping-border);
    margin: 1.25rem 0;
    background: repeating-linear-gradient(90deg, var(--ping-border) 0, var(--ping-border) 4px, transparent 4px, transparent 8px);
  }

  .tb-parallel {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    justify-content: center;
  }

  .tb-parallel-cmd {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ping-text);
    background: var(--ping-surface);
    border: 1px solid var(--ping-border);
    padding: 0.25rem 0.75rem;
    border-radius: 0.375rem;
  }

  .tb-parallel-desc {
    font-size: 0.75rem;
    color: var(--ping-text-muted);
  }
</style>
