---
import KrokiDiagram from './KrokiDiagram.astro';

const source = `
graph TD
  S["📦 <b>packages/shared</b><br/><code>pnpm build</code>"]
  W["🖥️ <b>apps/web</b><br/><code>pnpm build</code>"]
  D["📖 <b>apps/docs</b><br/><code>pnpm build</code>"]
  L["🔍 <b>lint</b><br/><i>all packages — parallel, no deps</i>"]
  T["✅ <b>typecheck</b><br/><i>all packages — parallel, no deps</i>"]

  S -->|"^build dependency"| W
  S -->|"^build dependency"| D

  style S fill:#ede9fe,stroke:#8b5cf6,color:#3b1f7e
  style W fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f
  style D fill:#d1fae5,stroke:#10b981,color:#064e3b
  style L fill:#f3f4f6,stroke:#6b7280,color:#1f2937
  style T fill:#f3f4f6,stroke:#6b7280,color:#1f2937
`;
---

<KrokiDiagram source={source} alt="Turborepo build pipeline: shared builds first, then web and docs in parallel; lint and typecheck run independently" />
