---
import KrokiDiagram from './KrokiDiagram.astro';

const source = `
sequenceDiagram
  participant U as User / Frontend
  participant C as Convex Backend
  participant AI as AI Services

  U->>C: 1. Send message (mutation)
  Note over C: Store in DB<br/>(optimistic update)
  C-->>U: 2. Real-time broadcast (WebSocket)
  Note over U: Subscribed clients re-render

  C->>AI: 3. Trigger background action
  Note over AI: Inbox summaries<br/>Proactive alerts<br/>Knowledge graph

  AI-->>C: 4. Write AI results to DB
  C-->>U: Inbox & alerts update reactively
`;
---

<KrokiDiagram source={source} alt="Request flow: user sends message, Convex stores and broadcasts, AI processes in background, results pushed to UI" />
