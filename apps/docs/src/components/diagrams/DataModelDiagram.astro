---
import KrokiDiagram from './KrokiDiagram.astro';

const source = `
erDiagram
  workspaces ||--o{ users : "workspaceId"
  workspaces ||--o{ channels : "workspaceId"
  workspaces ||--o{ directConversations : "workspaceId"
  workspaces ||--o{ integrationObjects : "workspaceId"
  workspaces ||--o{ invitations : "workspaceId"

  users ||--o{ channelMembers : "userId"
  users ||--o{ directConversationMembers : "userId"
  users ||--o{ inboxSummaries : "userId"
  users ||--o{ proactiveAlerts : "userId"
  users ||--o{ drafts : "userId"
  users ||--o{ sessions : "userId"
  users ||--o{ reactions : "userId"
  users ||--o{ typingIndicators : "userId"

  channels ||--o{ messages : "channelId"
  channels ||--o{ channelMembers : "channelId"
  channels ||--o{ typingIndicators : "channelId"

  directConversations ||--o{ directMessages : "conversationId"
  directConversations ||--o{ directConversationMembers : "conversationId"
`;
---

<KrokiDiagram source={source} alt="PING data model: 16 tables with workspaces, users, channels, conversations, messages, and supporting entities" />
