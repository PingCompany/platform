---
---

<section class="hero">
  <div class="hero-inner">
    <h1 class="hero-title">PING Documentation</h1>
    <p class="hero-subtitle">
      Everything you need to build with and use the AI-native workspace
    </p>
    <div class="hero-actions">
      <a href="/Platform/getting-started/introduction/" class="hero-btn hero-btn-primary">
        Get Started
      </a>
      <a href="/Platform/api/overview/" class="hero-btn hero-btn-secondary">
        API Reference
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    width: 100%;
    padding: 4rem 1.5rem;
    background: linear-gradient(135deg, #5e6ad2 0%, #3d4299 50%, #2a2e6e 100%);
    text-align: center;
  }

  .hero-inner {
    max-width: 48rem;
    margin: 0 auto;
  }

  .hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #fff;
    margin: 0 0 1rem;
    line-height: 1.1;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 2rem;
    line-height: 1.5;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .hero-btn:hover {
    opacity: 0.9;
  }

  .hero-btn-primary {
    background: #fff;
    color: #5e6ad2;
  }

  .hero-btn-secondary {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.3);
  }
</style>
