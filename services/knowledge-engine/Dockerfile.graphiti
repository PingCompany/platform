FROM zepai/graphiti:latest

USER root
RUN cp /root/.local/bin/uv /usr/local/bin/uv && \
    cp /root/.local/bin/uvx /usr/local/bin/uvx 2>/dev/null; true

# Patch: NEO4J_DATABASE env var support (upstream issue #715)
# Installs as sitecustomize.py so it runs before any app code
COPY patches/neo4j_database_support.py /app/.venv/lib/python3.12/site-packages/sitecustomize.py

USER app

CMD ["/app/.venv/bin/uvicorn", "graph_service.main:app", "--host", "0.0.0.0", "--port", "8000"]
