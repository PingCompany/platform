{
  "eval_id": 2,
  "eval_name": "full-regenerate",
  "prompt": "Our swagger is out of date, can you rescan all the convex functions and rebuild the openapi.yaml?",
  "assertions": [
    {"name": "covers_all_user_functions", "description": "Includes all 3 user functions"},
    {"name": "covers_all_channel_functions", "description": "Includes all 4 channel functions"},
    {"name": "covers_workspace_functions", "description": "Includes both workspace functions"},
    {"name": "covers_http_webhook", "description": "Includes /webhooks/workos"},
    {"name": "has_domain_schemas", "description": "Defines User, Workspace, Channel schemas"},
    {"name": "valid_yaml", "description": "Output is valid YAML"},
    {"name": "no_internal_functions", "description": "Does not expose internal helpers as endpoints"}
  ]
}
